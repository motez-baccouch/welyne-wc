generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Stage {
  GROUP
  R32
  R16
  QF
  SF
  THIRD
  FINAL
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
}

model User {
  id           Int          @id @default(autoincrement())
  username     String       @unique
  name         String
  passwordHash String
  avatar       String?
  role         String       @default("Member")
  isAdmin      Boolean      @default(false)
  points       Int          @default(0)
  predictions  Prediction[]
  championTeamId Int?
  championTeam   Team?      @relation("Champion", fields: [championTeamId], references: [id])
  createdAt    DateTime     @default(now())
}

model Team {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  flag      String   @default("")
  groupName String?
  odds      Float?   // indicative title-winner decimal odds
  homeMatches Match[] @relation("HomeTeam")
  awayMatches Match[] @relation("AwayTeam")
  champions   User[]  @relation("Champion")
}

model Match {
  id          Int          @id @default(autoincrement())
  code        String       @unique
  stage       Stage
  groupName   String?
  matchday    Int?
  kickoff     DateTime
  venue       String?
  status      MatchStatus  @default(SCHEDULED)

  homeTeamId  Int?
  homeTeam    Team?        @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeamId  Int?
  awayTeam    Team?        @relation("AwayTeam", fields: [awayTeamId], references: [id])

  // For knockout slots before teams are known, e.g. "Winner Group A", "Runner-up B"
  homePlaceholder String?
  awayPlaceholder String?

  homeScore   Int?
  awayScore   Int?

  predictions Prediction[]
}

model Prediction {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  matchId   Int
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  homePred  Int
  awayPred  Int
  points    Int      @default(0)
  scored    Boolean  @default(false)
  updatedAt DateTime @updatedAt

  @@unique([userId, matchId])
}
