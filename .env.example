# ── Database (Vercel → Storage → Neon Postgres injects this automatically) ──
# For local dev, paste your Neon connection string here.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ── Auth: secret used to sign login session cookies. Use any long random string. ──
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET="change-me-to-a-long-random-string"

# ── Protects the one-time /api/setup seeding endpoint and the /api/sync endpoint ──
SETUP_SECRET="another-long-random-string"

# ── football-data.org free API token (https://www.football-data.org/client/register) ──
# Optional — the app works with bundled fixtures without it. Used by /api/sync to pull live results.
FOOTBALL_DATA_TOKEN=""

# ── Password suffix appended to each member's first name to form their password ──
# e.g. PASSWORD_SUFFIX="0*" means user "motez" has password "motez0*"
PASSWORD_SUFFIX="0*"
